{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "MSERVE",
	"version": "3.2.1",
	"identifier": "com.mserve.webapp",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "MSERVE",
				"width": 1200,
				"height": 800,
				"decorations": false,
				"visible": false
			},
			{
				"label": "splashscreen",
				"title": "MSERVE",
				"url": "/splashscreen.html",
				"width": 1200,
				"height": 800,
				"decorations": false,
				"resizable": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3NTA0QTcyMUE4RkU0QUEKUldTcTVJOGFja3BRdDhHOFZCTGNuQ3drcWtGRFR1d2pMRmh5UkxvVEwrMnNPazM4RzkzbFVTUS8K",
			"endpoints": ["https://github.com/thetimblank/mserve3/releases/latest/download/latest.json"],
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
